# ── Backend .env ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

PORT=3001
NODE_ENV=development

# MongoDB — get from Atlas after changing your password
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_NEW_PASSWORD@cluster0.mojpz.mongodb.net/visionai?retryWrites=true&w=majority

# Optional JWT secret for future auth
JWT_SECRET=replace_with_random_64char_string
